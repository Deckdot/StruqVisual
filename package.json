{
  "name": "struq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "verify:design": "tsx scripts/verify-design.ts",
    "verify": "npm run typecheck && npm run lint && npm run verify:design && npm run build",
    "verify:full": "npm run verify && npm run test:e2e",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "tsx scripts/db-migrate.ts",
    "db:seed": "tsx scripts/import-canon.ts && tsx lib/db/seed.ts",
    "db:seed:assert": "tsx scripts/seed-assert.ts",
    "docker:up": "docker compose up -d db",
    "docker:reset": "docker compose down -v && docker compose up -d db"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@gsap/react": "^2.1.2",
    "@iconify/react": "^5.2.1",
    "@node-rs/argon2": "^2.0.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.29.0",
    "gsap": "^3.14.2",
    "lenis": "^1.3.25",
    "lucide-react": "^0.562.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.30",
    "postgres": "^3.4.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.182.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.9",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.185.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.10",
    "js-yaml": "^5.2.1",
    "postcss": "^8.4.47",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
