# Core application
NODE_ENV=development
AUTH_URL=http://localhost:3000
AUTH_SECRET=replace_with_a_long_random_secret
AUTH_TRUST_HOST=true
ADMIN_EMAIL=admin@struq.nl
NEXT_PUBLIC_SITE_URL=https://struq.nl
NEXT_PUBLIC_APP_URL=http://localhost:3000
GOOGLE_SITE_VERIFICATION=

# Playwright / E2E
# Matches the seeded local demo account from lib/db/seed.ts (pro tier)
PLAYWRIGHT_BASE_URL=http://localhost:3000
E2E_EMAIL=demo@struq.nl
E2E_PASSWORD=Struq2026

# Database
DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require
DATABASE_URL_MIGRATION=postgres://user:password@host:5432/database?sslmode=require
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_SECONDS=20
DB_SSL=require

# Auth providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=

# Optional: Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: AI / LLM
OPENAI_API_KEY=your_openai_key
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_CLEANUP_MODEL=deepseek/deepseek-v4-pro
OPENROUTER_STT_MODEL=openai/whisper-large-v3-turbo
OPENROUTER_STT_FALLBACK_MODEL=openai/gpt-4o-transcribe

# OpenCode Go
OPENCODE_API_KEY=your_opencode_api_key
OPENCODE_API_URL=https://opencode.ai/zen/go/v1/chat/completions
OPENCODE_MODEL=deepseek-v4-flash


# Web push / reminders
