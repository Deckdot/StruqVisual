# ─────────────────────────────────────────────────────────────
# Struq — environment template. Copy to .env.local and fill in.
# .env.local is gitignored. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Core application
NODE_ENV=development
# Auth.js: the canonical URL of this deployment (Railway sets this to the
# public domain in production). Locally, the dev server URL.
AUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace_with_a_long_random_secret
# Required behind Railway's proxy so Auth.js trusts the forwarded host.
AUTH_TRUST_HOST=true
NEXT_PUBLIC_SITE_URL=https://struq.nl
GOOGLE_SITE_VERIFICATION=

# Database — local dev points at Docker Postgres (docker-compose.yml).
# In production, Railway's Postgres plugin injects DATABASE_URL for you.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/struq
DATABASE_URL_MIGRATION=postgres://postgres:postgres@localhost:5432/struq
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_SECONDS=20
# 'disable' for local Docker, 'require' for a managed/remote Postgres.
DB_SSL=disable

# Auth providers — OAuth lights up only when both id + secret are present.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# OpenCode Go
OPENCODE_API_KEY=your_opencode_api_key
OPENCODE_API_URL=https://opencode.ai/zen/go/v1/chat/completions
OPENCODE_MODEL=deepseek-v4-flash

# Playwright / E2E — matches the seeded local demo account (lib/db/seed.ts).
PLAYWRIGHT_BASE_URL=http://localhost:3000
E2E_EMAIL=demo@struq.nl
E2E_PASSWORD=Struq2026

# ── Deferred (seams exist; not wired yet) ────────────────────
# Billing / Stripe — add when the M5 Stripe slice lands.
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRODUCT_PRO=
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_PRO_YEARLY=
